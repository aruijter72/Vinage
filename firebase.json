{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "codebase": "default",
      "source": "functions",
      "runtime": "nodejs22",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "autopush.sh",
      ".git",
      ".git/**",
      ".gitignore",
      "*.md",
      "node_modules",
      "node_modules/**",
      "functions",
      "functions/**",
      "**/.env",
      "**/.DS_Store"
    ],
    "rewrites": [
      { "source": "/app",                   "destination": "/app.html" },
      { "source": "/app/**",                "destination": "/app.html" },
      { "source": "/pricing",               "destination": "/website/pricing.html" },
      { "source": "/about",                 "destination": "/website/about.html" },
      { "source": "/blog",                  "destination": "/website/blog.html" },
      { "source": "/privacy",               "destination": "/website/privacy.html" },
      { "source": "/privacy.html",          "destination": "/website/privacy.html" },
      { "source": "/gebruiksvoorwaarden",   "destination": "/website/terms.html" },
      { "source": "/terms",                 "destination": "/website/terms.html" },
      { "source": "/terms.html",            "destination": "/website/terms.html" }
    ]
  }
}
