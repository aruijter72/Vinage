rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Beta access codes ─────────────────────────────────────────────────────
    // Codes are read by signed-in users to verify redemption.
    // Write is console-only (admin manages codes manually in Firestore).
    match /betaCodes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── App config (e.g. config/importers) ────────────────────────────────────
    // Public read so partner suggestions work even when signed out / offline.
    // Non-sensitive (on/off flags). Write is console-only (admin-managed).
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Geography overview cache (Explore feature) ────────────────────────────
    // Educational country/region overviews generated by the AI on first view.
    // Public read so the cache benefits everyone. Authenticated users may
    // populate the cache (size-capped) — payload is the model's structured
    // overview JSON, no personal data.
    match /regionInfo/{slug} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.payload is map
        && request.resource.data.lang is string
        && request.resource.data.lang.size() <= 4;
      allow delete: if false;
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    // Each user can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Households ────────────────────────────────────────────────────────────
    match /households/{householdId} {

      // Any signed-in user can READ household metadata.
      // This is required so the invite-code lookup query works:
      //   db.collection('households').where('inviteCode', '==', code)
      // Without this, a non-member gets "permission denied" before they can
      // even find the household to join.
      allow read: if request.auth != null;

      // Any signed-in user can CREATE a new household.
      allow create: if request.auth != null;

      // Any signed-in user can UPDATE a household.
      // This covers two cases:
      //   1. An existing member making changes (name, etc.)
      //   2. A new user adding themselves to the members map (joining).
      allow update: if request.auth != null;

      // Only the original creator can delete a household.
      allow delete: if request.auth != null &&
                       resource.data.createdBy == request.auth.uid;

      // ── Wines subcollection ─────────────────────────────────────────────────
      // Read and write are allowed only if the requesting user is listed in
      // the parent household's members map.
      match /wines/{wineId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/households/$(householdId))
            .data.members[request.auth.uid] != null;
      }

      // ── Cellars subcollection ───────────────────────────────────────────────
      match /cellars/{cellarId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/households/$(householdId))
            .data.members[request.auth.uid] != null;
      }

      // ── Consumption subcollection ────────────────────────────────────────────
      // Stores open-bottle history. All household members can read and write,
      // so Stats sync correctly across all devices in real time.
      match /consumption/{entryId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/households/$(householdId))
            .data.members[request.auth.uid] != null;
      }
    }

    // ── Community reviews (global, cross-user) ────────────────────────────────
    // Any signed-in user can READ all reviews (shown anonymously in the app).
    // A user may only CREATE/UPDATE/DELETE a review whose `uid` is their own,
    // with a rating of 1–5 and a note no longer than 800 characters.
    match /communityReviews/{reviewId} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 800
        && request.resource.data.wineKey is string
        && request.resource.data.wineKey.size() > 0;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
